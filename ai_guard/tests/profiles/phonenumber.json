        {
            "type": "PATTERN",
            "name": "Append Following 7 Digits",
            "inverse": false,
            "include_expand": true,
            "likelihoodAdjustment": {
                "type": "SET",
                "setLikelihood": "LIKELY"
            },
            "target": "CONTEXT",
            "context": {
                "windowAfter": 15
            },
            "pattern": {
                "regex": "^\\)?[ -\\.]?[0-9]{3}[ -\\.]?[0-9]{4}\\b",
                "flags": "g",
                "groupIndexes": null
            }
        },
        {
            "type": "PATTERN",
            "name": "Prepend Possible Missing (",
            "inverse": false,
            "include_expand": true,
            "likelihoodAdjustment": {
                "type": "ADJUST",
                "adjustLikelihood": 0
            },
            "target": "CONTEXT",
            "context": {
                "windowBefore": 3
            },
            "pattern": {
                "regex": "\\($",
                "flags": "gm"
            }
        },
        {
            "type": "PATTERN",
            "name": "Prepend National Code",
            "inverse": false,
            "include_expand": true,
            "likelihoodAdjustment": {
                "type": "SET",
                "setLikelihood": "LIKELY"
            },
            "target": "CONTEXT",
            "context": {
                "windowBefore": 10
            },
            "pattern": {
                "regex": "(?:\\+0?1|\\b0?1)[- ]{0,3}$",
                "flags": "gm"
            }
        },
        {
            "type": "PATTERN",
            "name": "Check If Finding Is Unformatted",
            "inverse": false,
            "include_expand": false,
            "likelihoodAdjustment": {
                "type": "SET",
                "setLikelihood": "UNLIKELY"
            },
            "target": "FINDING",
            "pattern": {
                "regex": "[0-9]{10,11}$",
                "flags": "gm"
            }
        },
        {
            "name": "Unbalanced Dashes Periods and Parenthesis or Spaces",
            "description": "Reduce likelihood if finding is uneven or missing spaces like (539-267.1234, 555-343.4233, 555343-4233, 539343.4233",
            "inverse": false,
            "include_expand": false,
            "target": "FINDING",
            "type": "PATTERN",
            "likelihoodAdjustment": {
                "type": "SET",
                "setLikelihood": "UNLIKELY"
            },
            "pattern": {
                "regex": "^(?:\\((?:\\d{3}\\-\\d{3}\\.|\\d{6}\\-|(?:\\d{3}\\.){2})\\d{4}|(?:\\d{3}(?:\\-\\d{3}[ .]|\\.\\d{3}[ \\-])|\\d{6}[ \\-.])\\d{4}|\\d{3}\\)\\d{7})$",
                "_notes": "https://regex101.com/r/Xf5opd/4"
            }
        },
        {
            "name": "Extension up to 6 digits",
            "type": "PATTERN",
            "inverse": false,
            "likelihoodAdjustment": {
                "type": "SET",
                "setLikelihood": "VERY_LIKELY"
            },
            "pattern": {
                "regex": "^ ?(?:#|x\\.?|ext\\.?|extension) ?\\d{1,6}\\b",
                "flags": "gi",
                "_notes": "https://regex101.com/r/M9yZmr/1"
            },
            "includeExpand": true,
            "target": "CONTEXT",
            "context": {
                "windowAfter": 40
            }
        },

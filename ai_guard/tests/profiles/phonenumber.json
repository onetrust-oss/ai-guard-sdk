            "name": "Formatted And Unformatted U.S. Phone Number",
            "type": "PATTERN",
            "prerequisite": {
                "minLength": 10,
                "requirements": [
                    "N"
                ]
            },
            "pattern": {
                "regex": "\\b1?([0-9]{3})\\)?[ \\-\\.]{0,3}[0-9]{3}[ \\-\\.]{0,3}[0-9]{4}\\b",
                "flags": "g",
                "groupIndexes": [
                    1
                ],
                "_note": "https://regex101.com/r/aJZ03a/1"
            },
            "likelihood": "LIKELY",
            "description": "Formatted US phone number and return area code as start point"
        }
    ],
